# ─── Required ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/freshmart
SESSION_SECRET=change-this-to-a-random-string-of-at-least-32-characters
PORT=3000
NODE_ENV=development

# ─── Optional: SMS Notifications (Fast2SMS) ─────────────────────
# Get your key at https://fast2sms.com
FAST2SMS_API_KEY=

# ─── Optional: Object Storage (Cloudflare R2) ───────────────────
# If not set, uploaded images are stored on the local filesystem.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ─── Optional: AI Features ──────────────────────────────────────
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ─── Optional: Logging ──────────────────────────────────────────
# Levels: trace | debug | info | warn | error
LOG_LEVEL=info
